# Environment Configuration for PDF-Flow Backend
# Copy this file to .env and fill in your values

# ============================================
# Core Settings
# ============================================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars

# ============================================
# Database (Supabase PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/pdfflow

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# CORS & Security
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# Stripe (Payment Processing)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxx
STRIPE_PRICE_ID_YEARLY=price_xxxxx

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=PDF-Flow <noreply@pdf-flow.com>
FRONTEND_URL=http://localhost:5173

# ============================================
# OAuth (Google)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:8000/api/v1/auth/oauth/google/callback
# ============================================
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# ============================================
# OAuth (GitHub)
# Get credentials from: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/api/v1/auth/oauth/github/callback
# ============================================
GITHUB_CLIENT_ID=xxxxx
GITHUB_CLIENT_SECRET=xxxxx

# ============================================
# OAuth Redirect URL (Backend base URL for OAuth callbacks)
# ============================================
OAUTH_REDIRECT_URL=http://localhost:8000

# ============================================
# OCR (Tesseract)
# ============================================
TESSERACT_PATH=/usr/bin/tesseract

# ============================================
# Monitoring (Optional)
# ============================================
SENTRY_DSN=
POSTHOG_API_KEY=
